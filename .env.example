# ────────────────────────────────────────────────────────────────────────
#  askDataAI — Environment Variables
#  Copy file này thành .env và điền thông tin thực vào.
#  KHÔNG commit file .env lên git.
# ────────────────────────────────────────────────────────────────────────

# ── SQL Server Connection ────────────────────────────────────────────────
# Dùng 'localhost' khi chạy thủ công
# Dùng 'host.docker.internal' khi chạy bằng Docker
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DB=YourDatabaseName
SQL_SERVER_USER=sa
SQL_SERVER_PASS=your_strong_password_here

# ── OpenAI ───────────────────────────────────────────────────────────────
# Lấy API key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB (vector store lưu schema embeddings) ────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Knowledge files ──────────────────────────────────────────────────────
GLOSSARY_PATH=./glossary.yaml
MEMORY_PATH=./semantic_memory.json
