# ────────────────────────────────────────────────────────────────
#  askDataAI — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ────────────────────────────────────────────────────────────────

# ── SQL Server Connection ──────────────────────────────────────
# Use 'localhost' when running locally (source mode)
# Use 'host.docker.internal' when running via Docker
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DB=AdventureWorksDW2025
SQL_SERVER_USER=sa
SQL_SERVER_PASS=your_strong_password_here

# ── LLM Provider (OpenAI-compatible) ──────────────────────────
# Option 1: OpenAI
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.openai.com/v1

# Option 2: GitHub Models (free, requires GitHub PAT)
#   OPENAI_API_KEY=ghp_...
#   OPENAI_BASE_URL=https://models.github.ai/inference

# Option 3: Any OpenAI-compatible provider (Groq, Together, etc.)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://models.github.ai/inference
OPENAI_MODEL=gpt-4.1-mini

# ── ChromaDB (vector store for schema embeddings) ─────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Knowledge files ────────────────────────────────────────────
GLOSSARY_PATH=./glossary.yaml
MEMORY_PATH=./semantic_memory.json
